@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Systems Manager infrastructure ontology — managed compute boundaries and their
# OS-level resources. The native ingestion path stores opaque references and operational
# attributes; it intentionally excludes hostnames, addresses, hardware addresses,
# filesystem paths, user identity, and credential material.

:HardwareNode a owl:Class ;
    rdfs:label "Hardware Node" ;
    rdfs:comment "A managed physical or virtual compute boundary identified by an opaque deployment reference." .

:NetworkInterface a owl:Class ;
    rdfs:label "Network Interface" ;
    rdfs:comment "A network interface on a HardwareNode, represented without an address, hardware address, or local interface name." .

:DiskVolume a owl:Class ;
    rdfs:label "Disk Volume" ;
    rdfs:comment "A disk volume on a HardwareNode represented without a device name, serial number, or filesystem path." .

:SystemService a owl:Class ;
    rdfs:label "System Service" ;
    rdfs:comment "An OS-managed service/unit (systemd or Windows service) on a HardwareNode (sm_service_operations list_services)." .

:SoftwarePackage a owl:Class ;
    rdfs:label "Software Package" ;
    rdfs:comment "An installed or upgradable OS software package on a HardwareNode (sm_system_operations list_installed_packages)." .

# --- links (owl:ObjectProperty) ---

:hasInterface a owl:ObjectProperty ;
    rdfs:label "has interface" ;
    rdfs:comment "Links a HardwareNode to a NetworkInterface it exposes." ;
    rdfs:domain :HardwareNode ;
    rdfs:range :NetworkInterface .

:hasVolume a owl:ObjectProperty ;
    rdfs:label "has volume" ;
    rdfs:comment "Links a HardwareNode to a DiskVolume mounted on it." ;
    rdfs:domain :HardwareNode ;
    rdfs:range :DiskVolume .

:runsService a owl:ObjectProperty ;
    rdfs:label "runs service" ;
    rdfs:comment "Links a HardwareNode to a SystemService it runs." ;
    rdfs:domain :HardwareNode ;
    rdfs:range :SystemService .

:hasPackage a owl:ObjectProperty ;
    rdfs:label "has package" ;
    rdfs:comment "Links a HardwareNode to a SoftwarePackage installed on it." ;
    rdfs:domain :HardwareNode ;
    rdfs:range :SoftwarePackage .

# --- fields (owl:DatatypeProperty) ---

:externalToolId a owl:DatatypeProperty ;
    rdfs:label "opaque source reference" ;
    rdfs:comment "A stable, one-way reference derived within the connector's namespace; never a raw local identifier." ;
    rdfs:range xsd:string .

:osVersion a owl:DatatypeProperty ;
    rdfs:label "os version" ;
    rdfs:comment "Operating-system name/release/version string of a HardwareNode (from get_os_statistics)." ;
    rdfs:range xsd:string .

:machineArch a owl:DatatypeProperty ;
    rdfs:label "machine architecture" ;
    rdfs:comment "CPU architecture of a HardwareNode (e.g. x86_64, aarch64)." ;
    rdfs:range xsd:string .

:processor a owl:DatatypeProperty ;
    rdfs:label "processor family" ;
    rdfs:comment "A non-unique processor architecture or family description." ;
    rdfs:domain :HardwareNode ;
    rdfs:range xsd:string .

:cpuCount a owl:DatatypeProperty ;
    rdfs:label "cpu count" ;
    rdfs:comment "Number of logical CPUs on a HardwareNode (from get_hardware_statistics)." ;
    rdfs:range xsd:integer .

:memoryTotal a owl:DatatypeProperty ;
    rdfs:label "memory total" ;
    rdfs:comment "Total physical memory in bytes on a HardwareNode." ;
    rdfs:range xsd:integer .

:linkSpeed a owl:DatatypeProperty ;
    rdfs:label "link speed" ;
    rdfs:comment "Negotiated link speed of a NetworkInterface in Mbps." ;
    rdfs:domain :NetworkInterface ;
    rdfs:range xsd:integer .

:isUp a owl:DatatypeProperty ;
    rdfs:label "is up" ;
    rdfs:comment "Whether a NetworkInterface is administratively/operationally up." ;
    rdfs:domain :NetworkInterface ;
    rdfs:range xsd:boolean .

:mtu a owl:DatatypeProperty ;
    rdfs:label "maximum transmission unit" ;
    rdfs:comment "Maximum transmission unit reported for a NetworkInterface." ;
    rdfs:domain :NetworkInterface ;
    rdfs:range xsd:integer .

:addressFamilyCount a owl:DatatypeProperty ;
    rdfs:label "address family count" ;
    rdfs:comment "Number of address families observed without retaining the addresses themselves." ;
    rdfs:domain :NetworkInterface ;
    rdfs:range xsd:integer .

:fstype a owl:DatatypeProperty ;
    rdfs:label "filesystem type" ;
    rdfs:comment "Filesystem type of a DiskVolume (ext4, xfs, ntfs, …)." ;
    rdfs:domain :DiskVolume ;
    rdfs:range xsd:string .

:capacityBytes a owl:DatatypeProperty ;
    rdfs:label "capacity bytes" ;
    rdfs:comment "Total capacity of a DiskVolume in bytes." ;
    rdfs:domain :DiskVolume ;
    rdfs:range xsd:integer .

:usedBytes a owl:DatatypeProperty ;
    rdfs:label "used bytes" ;
    rdfs:comment "Used capacity of a DiskVolume in bytes." ;
    rdfs:domain :DiskVolume ;
    rdfs:range xsd:integer .

:freeBytes a owl:DatatypeProperty ;
    rdfs:label "free bytes" ;
    rdfs:comment "Available capacity of a DiskVolume in bytes." ;
    rdfs:domain :DiskVolume ;
    rdfs:range xsd:integer .

:percentUsed a owl:DatatypeProperty ;
    rdfs:label "percent used" ;
    rdfs:comment "Percentage of a DiskVolume currently in use." ;
    rdfs:domain :DiskVolume ;
    rdfs:range xsd:decimal .

:serviceState a owl:DatatypeProperty ;
    rdfs:label "service state" ;
    rdfs:comment "Lifecycle state of a SystemService (active, inactive, failed, running, stopped)." ;
    rdfs:domain :SystemService ;
    rdfs:range xsd:string .

:serviceDescription a owl:DatatypeProperty ;
    rdfs:label "service description" ;
    rdfs:comment "A non-secret operating-system description of a SystemService." ;
    rdfs:domain :SystemService ;
    rdfs:range xsd:string .

<http://knuckles.team/kg/systems> a owl:Ontology ;
    rdfs:label "Systems Manager Ontology" ;
    rdfs:comment """Systems Manager infrastructure model — managed compute boundaries and
    their OS-level resources, represented with opaque source references and operational
    attributes through the governed knowledge-graph boundary.""" ;
    owl:imports <http://knuckles.team/kg> .
